    {
      "id": 5,
      "title": "Error Auto-Resolution Rate (%)",
      "description": "Percentage of errors automatically resolved vs total errors (auto-resolved + suggested). Higher is better.",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "sum(endorsement_error_auto_resolved_total{application=\"endorsement-service\"}) / (sum(endorsement_error_auto_resolved_total{application=\"endorsement-service\"}) + sum(endorsement_error_suggested_total{application=\"endorsement-service\"}))",
          "legendFormat": "Auto-Resolution Rate",
          "interval": "",
          "editorMode": "code"
        }
      ]
