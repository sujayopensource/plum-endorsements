{
  "id": null,
  "uid": "reconciliation-monitoring",
  "title": "Endorsement Service - Reconciliation Monitoring",
  "description": "Reconciliation run tracking, match rates, discrepancy detection, and duration analysis across insurers",
  "tags": ["endorsement-service", "reconciliation", "monitoring"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "links": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "title": "Reconciliation Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Reconciliation Runs",
      "description": "Number of completed reconciliation runs in the last 24 hours by insurer",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 4 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "increase(endorsement_reconciliation_completed_total{application=\"endorsement-service\"}[24h])",
          "legendFormat": "{{insurerId}}",
          "interval": "",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "title": "Match Rate",
      "description": "Percentage of reconciliation records that matched successfully",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "endorsement_reconciliation_matched{application=\"endorsement-service\"} / (endorsement_reconciliation_matched{application=\"endorsement-service\"} + endorsement_reconciliation_discrepancies{application=\"endorsement-service\"}) * 100",
          "legendFormat": "Match Rate",
          "interval": "",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "title": "Discrepancies",
      "description": "Current count of reconciliation discrepancies requiring attention",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "endorsement_reconciliation_discrepancies{application=\"endorsement-service\"}",
          "legendFormat": "Discrepancies",
          "interval": "",
          "editorMode": "code"
        }
      ]
    },
    {
      "type": "row",
      "title": "Reconciliation Detail",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "Reconciliation Errors",
      "description": "Rate of reconciliation errors per second broken down by insurer code",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "errors/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "area" }
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "rate(endorsement_reconciliation_error_total{application=\"endorsement-service\"}[5m])",
          "legendFormat": "{{insurerCode}}",
          "interval": "",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 5,
      "title": "Reconciliation Duration",
      "description": "Duration of reconciliation runs: median, 95th, and 99th percentile",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "duration",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(endorsement_reconciliation_duration_seconds_bucket{application=\"endorsement-service\"}[5m])) by (le))",
          "legendFormat": "p50 Duration",
          "interval": "",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(endorsement_reconciliation_duration_seconds_bucket{application=\"endorsement-service\"}[5m])) by (le))",
          "legendFormat": "p95 Duration",
          "interval": "",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(endorsement_reconciliation_duration_seconds_bucket{application=\"endorsement-service\"}[5m])) by (le))",
          "legendFormat": "p99 Duration",
          "interval": "",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 6,
      "title": "Outcome Distribution",
      "description": "Distribution of reconciliation outcomes: MATCH, PARTIAL_MATCH, REJECTED, and MISSING",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "MATCH" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "PARTIAL_MATCH" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "REJECTED" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "MISSING" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "endorsement_reconciliation_outcome_total{application=\"endorsement-service\", outcome=\"MATCH\"}",
          "legendFormat": "MATCH",
          "interval": "",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": "Prometheus",
          "expr": "endorsement_reconciliation_outcome_total{application=\"endorsement-service\", outcome=\"PARTIAL_MATCH\"}",
          "legendFormat": "PARTIAL_MATCH",
          "interval": "",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": "Prometheus",
          "expr": "endorsement_reconciliation_outcome_total{application=\"endorsement-service\", outcome=\"REJECTED\"}",
          "legendFormat": "REJECTED",
          "interval": "",
          "editorMode": "code"
        },
        {
          "refId": "D",
          "datasource": "Prometheus",
          "expr": "endorsement_reconciliation_outcome_total{application=\"endorsement-service\", outcome=\"MISSING\"}",
          "legendFormat": "MISSING",
          "interval": "",
          "editorMode": "code"
        }
      ]
    }
  ]
}
