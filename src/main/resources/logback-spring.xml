<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ============================================================ -->
    <!-- Profile: local dev (human-readable console)                  -->
    <!-- Activated when the "json" profile is NOT active               -->
    <!-- ============================================================ -->
    <springProfile name="!json">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} [traceId=%X{traceId:-} spanId=%X{spanId:-} requestId=%X{requestId:-} endorsementId=%X{endorsementId:-} employerId=%X{employerId:-}] - %msg%n</pattern>
            </encoder>
        </appender>

        <logger name="com.plum" level="DEBUG"/>
        <logger name="org.springframework.kafka" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ============================================================ -->
    <!-- Profile: json (structured JSON logging for production)        -->
    <!-- ============================================================ -->
    <springProfile name="json">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>endorsementId</includeMdcKeyName>
                <includeMdcKeyName>employerId</includeMdcKeyName>
                <customFields>{"service":"endorsement-service"}</customFields>
            </encoder>
        </appender>

        <appender name="LOGSTASH_TCP" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
            <destination>${LOGSTASH_HOST:-localhost}:5000</destination>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
            <keepAliveDuration>5 minutes</keepAliveDuration>
            <ringBufferSize>8192</ringBufferSize>
        </appender>

        <logger name="com.plum" level="DEBUG"/>
        <logger name="org.springframework.kafka" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="LOGSTASH_TCP"/>
        </root>
    </springProfile>
</configuration>
